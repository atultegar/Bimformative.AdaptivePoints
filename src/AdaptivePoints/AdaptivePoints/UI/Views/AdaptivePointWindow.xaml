<Window x:Class="BIMformative.AdaptivePoints.UI.Views.AdaptivePointWindow"       
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"             
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
        xmlns:local="clr-namespace:BIMformative.AdaptivePoints.UI.Views"
        mc:Ignorable="d"
        Title=""
        Height="560" 
        Width="950"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#252526"
        FontFamily="Segoe UI">

    <Window.Resources>
        
        <!--Colors-->

        <SolidColorBrush x:Key="BackgroundBrush" Color="#252526"/>
        <SolidColorBrush x:Key="CardBrush" Color="#2D2D30"/>
        <SolidColorBrush x:Key="BorderBrushDark" Color="#3E3E42"/>
        <SolidColorBrush x:Key="TextBrush" Color="#F1F1F1"/>
        <SolidColorBrush x:Key="SecondaryTextBrush" Color="#C8C8C8"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#007ACC"/>
        
        <!--Button Style-->

        <Style TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        
        <!--Textbox Style-->

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#1E1E1E"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#3E3E42"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6"/>
            <Setter Property="Margin" Value="0,4"/>
        </Style>
        
        <!--Listbox Style-->

        <Style TargetType="ListBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
    </Window.Resources>
    
    <Grid Margin="14">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        
        <!--LEFT PANEL-->
        <Border Grid.Column="0"
                Background="{StaticResource CardBrush}"
                BorderBrush="{StaticResource BorderBrushDark}"
                BorderThickness="1"
                CornerRadius="10"
                Padding="12">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="12" />
                    <RowDefinition />
                </Grid.RowDefinitions>

                <TextBlock Text="Reference Points"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextBrush}"/>

                <ListBox x:Name="lstRP"
                         Grid.Row="2"
                         SelectionChanged="lstRP_SelectionChanged"
                         SelectedIndex="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Auto"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"/>
            </Grid>            
        </Border>
        
        <!--RIGHT PANEL-->
        <Border Grid.Column="2"
                Background="{StaticResource CardBrush}"
                BorderBrush="{StaticResource BorderBrushDark}"
                BorderThickness="1"
                CornerRadius="10"
                Padding="16">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="20"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="20"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <!--HEADER-->
                <TextBlock Text="Adaptive Point Editor"
                           FontSize="20"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextBrush}"/>
                
                <!--INTERNAL CARD-->
                <Border Grid.Row="2"
                        Background="#333337"
                        CornerRadius="8"
                        Padding="14">

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="16"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="30"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="150"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.ColumnSpan="2" 
                                   Text="Internal Coordinates"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextBrush}"/>

                        <TextBlock Grid.Row="2" 
                                   Text="X"
                                   Foreground="{StaticResource SecondaryTextBrush}"
                                   VerticalAlignment="Center"/>
                        
                        <TextBox Grid.Row="2"
                                 Grid.Column="1" 
                                 x:Name="rvtX"
                                 TextAlignment="Right"
                                 IsEnabled="False"/>

                        <TextBlock Grid.Row="3" 
                                   Text="Y"
                                   Foreground="{StaticResource SecondaryTextBrush}"
                                   VerticalAlignment="Center"/>
                        
                        <TextBox Grid.Row="3"
                                 Grid.Column="1"
                                 x:Name="rvtY"
                                 TextAlignment="Right"
                                 IsEnabled="False"/>

                        <TextBlock Grid.Row="4" 
                                   Text="Z"
                                   Foreground="{StaticResource SecondaryTextBrush}"
                                   VerticalAlignment="Center"/>

                        <TextBox Grid.Row="4"
                                 Grid.Column="1" 
                                 x:Name="rvtZ"
                                 TextAlignment="Right"
                                 IsEnabled="False"/>

                        <Button Grid.Row="2"
                                Grid.Column="2"
                                Content="Edit"
                                x:Name="btnRvtEdit"
                                Width="100"
                                VerticalAlignment="Center"
                                Click="btnRvtEdit_Click"/>

                        <Button Grid.Row="3"
                                Grid.Column="2"
                                Content="Cancel"
                                x:Name="btnRvtCancel"
                                Width="100"
                                VerticalAlignment="Center"
                                Click="btnRvtCancel_Click"/>
                        
                        <Button Grid.Row="4"
                                Grid.Column="2"
                                Content="Apply"
                                x:Name="btnRvtApply"
                                Width="100"
                                VerticalAlignment="Center"
                                Click="btnRvtApply_Click"/>
                    </Grid>
                </Border>

                <!--SHARED CARD-->
                <Border Grid.Row="4"
                        Background="#333337"
                        CornerRadius="8"
                        Padding="14">

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="16"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="30"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="150"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Shared Coordinates"
                                   Grid.ColumnSpan="2"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextBrush}"/>
                        
                        <TextBlock Grid.Row="2" 
                                   Grid.Column="0"
                                   Text="X"
                                   Foreground="{StaticResource SecondaryTextBrush}"
                                   VerticalAlignment="Center"/>

                        <TextBox Grid.Row="2" 
                                 Grid.Column="1"
                                 x:Name="sharedX"
                                 TextAlignment="Right"
                                     IsEnabled="False"/>

                        <TextBlock Grid.Row="3"
                                   Grid.Column="0"
                                   Text="Y"
                                   Foreground="{StaticResource SecondaryTextBrush}"
                                   VerticalAlignment="Center"/>
                        
                        <TextBox Grid.Row="3"
                                 Grid.Column="1"
                                 x:Name="sharedY"
                                 TextAlignment="Right"
                                     IsEnabled="False"/>

                        <TextBlock Grid.Row="4"
                                   Grid.Column="0" 
                                   Text="Z"
                                   Foreground="{StaticResource SecondaryTextBrush}"
                                   VerticalAlignment="Center"/>

                        <TextBox Grid.Row="4"
                                 Grid.Column="1" 
                                 x:Name="sharedZ"
                                 TextAlignment="Right"
                                     IsEnabled="False"/>

                        <Button Grid.Row="2"
                                Grid.Column="2"
                                Content="Edit"
                                x:Name="btnSharedEdit"
                                Width="100"
                                VerticalAlignment="Center"
                                Click="btnSharedEdit_Click"/>
                        
                        <Button Grid.Row="3"
                                Grid.Column="2"
                                Content="Cancel"
                                x:Name="btnSharedCancel"
                                Width="100"
                                VerticalAlignment="Center"
                                Click="btnSharedCancel_Click"/>
                        
                        <Button Grid.Row="4"
                                Grid.Column="2"
                                Content="Apply"
                                x:Name="btnSharedApply"
                                Width="100"
                                VerticalAlignment="Center"
                                Click="btnSharedApply_Click"/>

                    </Grid>
                </Border>
                
                <!--FOOTER-->
                <StackPanel Grid.Row="5"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Margin="0,5,0,0">
                    <Button x:Name="btnReset"
                            Content="Reset"
                            Width="90"
                            Margin="6"                            
                            Click="btnReset_Click"/>

                    <Button x:Name="btnApply"
                            Content="Apply"
                            Width="90"
                            Margin="6"
                            Click="btnApply_Click"/>

                    <Button x:Name="btnOk"
                            Content="Ok"
                            Width="90"
                            Margin="6"
                            Click="btnOk_Click"/>

                    <Button x:Name="btnClose"
                            Content="Cancel"
                            Width="90"
                            Margin="6"
                            Click="btnClose_Click"/>
                </StackPanel>

            </Grid>
        </Border>
    </Grid>
</Window>
